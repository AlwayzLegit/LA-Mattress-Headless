# Copy to .env.local. NEVER commit .env.local.
# Vercel: set the same vars in Project Settings → Environment Variables.

# ─── Shopify Storefront API (read-only public token) ───────────────
# Required at runtime for /products, /collections, /pages, /cart routes.
# Get from: Shopify Admin → Settings → Apps and sales channels → Develop apps
#           → [your app] → Storefront API access tokens.
# Required scopes:
#   unauthenticated_read_product_listings
#   unauthenticated_read_product_inventory
#   unauthenticated_read_content
#   unauthenticated_write_checkouts
#   unauthenticated_read_checkouts
SHOPIFY_STORE_DOMAIN=la-mattress.myshopify.com
SHOPIFY_STOREFRONT_PUBLIC_TOKEN=
SHOPIFY_API_VERSION=2024-10

# ─── Site config ────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://mattressstoreslosangeles.com

# ─── Admin API (USED ONLY by scripts/pull-inventory.mjs, never by the app) ─
# Required scopes for the inventory pull script:
#   read_products, read_content, read_online_store_pages, read_themes
# Do not load this in the Next.js app — Storefront API only per the brief's
# hard rule #1 (read-only Storefront API in the storefront).
SHOPIFY_ADMIN_TOKEN=

# ─── Webhook secret (for /api/revalidate) ──────────────────────────────────
# Used to verify Shopify webhook signatures. Set to any long random string,
# then paste the SAME value into Shopify Admin → Settings → Notifications →
# Webhooks → "Webhook signing secret". Without this, /api/revalidate returns
# 503; webhooks just no-op until you wire it.
# Generate one: `openssl rand -hex 32`
SHOPIFY_WEBHOOK_SECRET=
