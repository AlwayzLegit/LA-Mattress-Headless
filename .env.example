# Copy to .env.local. NEVER commit .env.local.
# Vercel: set the same vars in Project Settings → Environment Variables.

# ─── Shopify Storefront API (read-only public token) ───────────────
# Required at runtime for /products, /collections, /pages, /cart routes.
# Get from: Shopify Admin → Settings → Apps and sales channels → Develop apps
#           → [your app] → Storefront API access tokens.
# Required scopes:
#   unauthenticated_read_product_listings
#   unauthenticated_read_product_inventory
#   unauthenticated_read_content
#   unauthenticated_write_checkouts
#   unauthenticated_read_checkouts
SHOPIFY_STORE_DOMAIN=la-mattress.myshopify.com
SHOPIFY_STOREFRONT_PUBLIC_TOKEN=
SHOPIFY_API_VERSION=2024-10

# ─── Site config ────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://mattressstoreslosangeles.com

# ─── Admin API (USED ONLY by scripts/pull-inventory.mjs, never by the app) ─
# Required scopes for the inventory pull script:
#   read_products, read_content, read_online_store_pages, read_themes
# Do not load this in the Next.js app — Storefront API only per the brief's
# hard rule #1 (read-only Storefront API in the storefront).
SHOPIFY_ADMIN_TOKEN=

# ─── Webhook secret (for /api/revalidate) ──────────────────────────────────
# Used to verify Shopify webhook signatures. Set to any long random string,
# then paste the SAME value into Shopify Admin → Settings → Notifications →
# Webhooks → "Webhook signing secret". Without this, /api/revalidate returns
# 503; webhooks just no-op until you wire it.
# Generate one: `openssl rand -hex 32`
SHOPIFY_WEBHOOK_SECRET=

# ─── Judge.me reviews (optional; powers /pages/reviews + homepage Reviews) ──
# When unset, both surfaces render nothing (graceful no-op).
# Get from Judge.me admin → Settings → API tokens.
JUDGEME_API_TOKEN=
JUDGEME_SHOP_DOMAIN=

# ─── Google Analytics 4 (optional, for search-engine attribution) ──────────
# When NEXT_PUBLIC_GA_MEASUREMENT_ID is unset, the GA4 component in
# app/_components/analytics-ga4.tsx renders nothing — safe to deploy without
# it. When set, gtag.js loads after hydration (afterInteractive) and Core
# Web Vitals are forwarded as GA4 events via useReportWebVitals.
#
# Required for the Search Console → GA4 integration that surfaces keyword
# attribution alongside session/conversion data. Wire it after creating a
# GA4 property at https://analytics.google.com/.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Server-side GA4 forwarding (purchase event from order-paid webhook).
# Without these set, GA4's "Total revenue" and "Items purchased" reports
# stay at zero — Shopify's hosted checkout fires no client-side purchase
# event from our domain, so the server-side mirror is mandatory for
# Shopping Ads / Performance Max ROAS attribution to work.
#
# Setup: GA4 Admin → Data Streams → [your stream] → Measurement Protocol
# API secrets → Create. Copy the displayed secret into Vercel.
#
# GA4_MEASUREMENT_ID is optional — falls back to NEXT_PUBLIC_GA_MEASUREMENT_ID
# above. Override only if you want a different stream for server traffic.
GA4_MEASUREMENT_ID=
GA4_MEASUREMENT_API_SECRET=

# ─── Search engine verification (optional) ─────────────────────────────────
# Used by Google Search Console and Bing Webmaster Tools to confirm site
# ownership. Both render as <meta> tags in <head>; both no-op when unset.
#
# Google: Search Console → Settings → Ownership verification → HTML tag.
#   Paste only the value after content="…", not the whole tag.
# Bing:   Webmaster Tools → Sites → Verify → Meta tag method.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# ─── Sentry (optional, for error tracking) ─────────────────────────────────
# When NEXT_PUBLIC_SENTRY_DSN is unset, the SDK silently no-ops at runtime —
# safe to deploy without these. When set, the @sentry/nextjs SDK initializes
# on client + server + edge runtimes. Phase 166 wired error.tsx + global-
# error.tsx to captureException, and next.config.mjs is wrapped with
# withSentryConfig for source map upload.
#
# Get DSN from Sentry → Project Settings → Client Keys (DSN). Use the same
# value for NEXT_PUBLIC_ and the server-side one unless you want separate
# projects per runtime.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Auth token for source map upload at build time. Without it, builds still
# succeed but prod stack traces stay minified. Get from Sentry → Settings →
# Auth Tokens (needs `project:releases` + `org:read` scope).
SENTRY_AUTH_TOKEN=
# Optional — only needed if .sentryclirc isn't present or you want to override.
SENTRY_ORG=
SENTRY_PROJECT=
